GEMINI_API_KEY="your_gemini_api_key"

OCR_OCR_PROVIDER=ollama

OCR_LLM_ROUTER_MODEL=gemini/gemini-2.5-flash

OCR_LLM_MODEL=gemini/gemini-2.5-flash

OCR_OLLAMA_BASE_URL=http://localhost:11434
OCR_OLLAMA_TIMEOUT=1800
# OCR_OLLAMA_VISION_MODEL=minicpm-v
OCR_OLLAMA_VISION_MODEL=openbmb/minicpm-v4.5
OCR_OLLAMA_VISION_MODEL=qwen3.5:397b-cloud

OCR_STORAGE_BACKEND=qdrant
OCR_QDRANT_URL=http://localhost:6333
OCR_DATABASE_URL=postgresql://postgres:root@localhost:5432/ocr_agent

OCR_CHUNK_SIZE=512
OCR_CHUNK_OVERLAP=51
OCR_CHUNK_STRATEGY=recursive
OCR_PAGES_PER_CHUNK=5
OCR_OUTPUT_DIR=./ocr_output